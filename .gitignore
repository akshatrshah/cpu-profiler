# =============================================================================
# .gitignore — perf-profiler
# =============================================================================

# ── Built binaries ────────────────────────────────────────────────────────────
profiler
tests/run_tests
tests/debug_runner
tests/test_target

# ── Test output files ─────────────────────────────────────────────────────────
*.html
*.folded
*.pprof.txt
flamegraph.*

# ── Coverage artefacts ────────────────────────────────────────────────────────
*.gcda
*.gcno
*.gcov

# ── Object files ──────────────────────────────────────────────────────────────
*.o
*.a
*.so

# ── The test script itself — local use only, not part of the public repo ──────
test_all.sh

# ── macOS junk ────────────────────────────────────────────────────────────────
.DS_Store
**/.DS_Store

# ── Editor files ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Temp / scratch ────────────────────────────────────────────────────────────
/tmp/
scratch/